# ── LLM ──────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── Reddit ────────────────────────────────────────────────────────────────────
# Get these at reddit.com/prefs/apps → Create app → type: script
REDDIT_CLIENT_ID=abc123XYZ
REDDIT_CLIENT_SECRET=secrettoken123
REDDIT_USER_AGENT=MedResearchAgent/1.0 by YourRedditUsername

# ── Git ───────────────────────────────────────────────────────────────────────
# Used by the git MCP server for commit authoring
GIT_USER_NAME=Jane Doe
GIT_USER_EMAIL=jane@example.com
# Personal access token for GitHub remote operations (repo, push, PR)
# Create at: github.com/settings/tokens → Fine-grained or classic PAT
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# ── Optional ──────────────────────────────────────────────────────────────────
# Raises PubMed rate limit from 3 req/s → 10 req/s (free NCBI account)
NCBI_EMAIL=jane@example.com
